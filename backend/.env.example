# Azure Authentication
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# Model API Keys
O1_API_KEY=your-o1-api-key
O3_API_KEY=your-o3-api-key
GPT41_API_KEY=your-gpt4-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Azure Subscription
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id

# Agent Endpoints
MEDPARSE_ENDPOINT=https://your-medparse-endpoint.inference.ml.azure.com/score
GPT5_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/deployments/gpt-4/chat/completions?api-version=2024-02-15-preview
DEEPSEEK_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/deployments/gpt-4/chat/completions?api-version=2024-02-15-preview

# Azure ML Studio Configuration
AZURE_ML_WORKSPACE_NAME=your-ml-workspace
AZURE_ML_RESOURCE_GROUP=your-resource-group
AZURE_ML_SUBSCRIPTION_ID=your-subscription-id

# MedParse Endpoint Configuration
AZURE_ML_MEDPARSE_ENDPOINT=https://your-medparse-endpoint.inference.ml.azure.com/score
AZURE_ML_MEDPARSE_PRIMARY_KEY=your-primary-key
AZURE_ML_MEDPARSE_SECONDARY_KEY=your-secondary-key
